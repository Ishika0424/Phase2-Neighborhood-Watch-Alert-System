{
  "info": {
    "name": "Community Resource Sharing API - Phase 1",
    "description": "API requests for Phase 1 user authentication, resource sharing, and skill sharing.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Authentication",
      "item": [
        {
          "name": "Register User",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"John Doe\",\n  \"email\": \"john@example.com\",\n  \"password\": \"password123\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/auth/register",
              "host": ["{{baseUrl}}"],
              "path": ["auth", "register"]
            }
          }
        },
        {
          "name": "Login User",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"john@example.com\",\n  \"password\": \"password123\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/auth/login",
              "host": ["{{baseUrl}}"],
              "path": ["auth", "login"]
            }
          }
        },
        {
          "name": "Get User Profile",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{authToken}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/auth/profile",
              "host": ["{{baseUrl}}"],
              "path": ["auth", "profile"]
            }
          }
        },
        {
          "name": "Update User Profile",
          "request": {
            "method": "PUT",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{authToken}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"John Doe Updated\",\n  \"phone\": \"+15551234567\",\n  \"locationName\": \"Oakridge Sector 3\",\n  \"address\": \"Apt 4B, Pine Towers\",\n  \"skills\": [\"Plumbing\", \"Tutoring\"],\n  \"resources\": [\"Drill Kit\", \"Laptop\"]\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/auth/profile",
              "host": ["{{baseUrl}}"],
              "path": ["auth", "profile"]
            }
          }
        }
      ]
    },
    {
      "name": "Resource Sharing",
      "item": [
        {
          "name": "Get Resources",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/resources?category=&search=&location=",
              "host": ["{{baseUrl}}"],
              "path": ["resources"],
              "query": [
                { "key": "category", "value": "" },
                { "key": "search", "value": "" },
                { "key": "location", "value": "" }
              ]
            }
          }
        },
        {
          "name": "Create Resource Listing",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{authToken}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Power Drill Kit\",\n  \"description\": \"18V cordless drill with driver bits. Please return fully charged.\",\n  \"category\": \"Tools\",\n  \"location\": \"Oakridge Sector 3\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/resources",
              "host": ["{{baseUrl}}"],
              "path": ["resources"]
            }
          }
        },
        {
          "name": "Request to Borrow Resource",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{authToken}}" }
            ],
            "url": {
              "raw": "{{baseUrl}}/resources/{{resourceId}}/request",
              "host": ["{{baseUrl}}"],
              "path": ["resources", "{{resourceId}}", "request"]
            }
          }
        },
        {
          "name": "Approve Borrow Request",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{authToken}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"requesterId\": \"{{requesterUserId}}\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/resources/{{resourceId}}/approve",
              "host": ["{{baseUrl}}"],
              "path": ["resources", "{{resourceId}}", "approve"]
            }
          }
        },
        {
          "name": "Return Resource",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{authToken}}" }
            ],
            "url": {
              "raw": "{{baseUrl}}/resources/{{resourceId}}/return",
              "host": ["{{baseUrl}}"],
              "path": ["resources", "{{resourceId}}", "return"]
            }
          }
        }
      ]
    },
    {
      "name": "Skill Sharing",
      "item": [
        {
          "name": "Get Skill Listings",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/skills?category=&search=",
              "host": ["{{baseUrl}}"],
              "path": ["skills"],
              "query": [
                { "key": "category", "value": "" },
                { "key": "search", "value": "" }
              ]
            }
          }
        },
        {
          "name": "Create Skill Listing",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{authToken}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"Math & Calculus Tutoring\",\n  \"description\": \"Offering tutoring help for algebra and calculus. High school level or lower.\",\n  \"category\": \"Tutoring\",\n  \"availability\": \"Weekends, 10 AM to 4 PM\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/skills",
              "host": ["{{baseUrl}}"],
              "path": ["skills"]
            }
          }
        },
        {
          "name": "Request Skill Assistance",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{authToken}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"message\": \"Hi, I need help preparing for my final exam next week. Are you available this Saturday?\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/skills/{{skillId}}/request",
              "host": ["{{baseUrl}}"],
              "path": ["skills", "{{skillId}}", "request"]
            }
          }
        },
        {
          "name": "Respond to Assistance Request",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{authToken}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"status\": \"Accepted\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/skills/{{skillId}}/requests/{{requestId}}",
              "host": ["{{baseUrl}}"],
              "path": ["skills", "{{skillId}}", "requests", "{{requestId}}"]
            }
          }
        }
      ]
    }
  ],
  "event": [
    {
      "listen": "prerequest",
      "script": {
        "type": "text/javascript",
        "exec": [""]
      }
    },
    {
      "listen": "test",
      "script": {
        "type": "text/javascript",
        "exec": [""]
      }
    }
  ],
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:5001/api",
      "type": "string"
    },
    {
      "key": "authToken",
      "value": "",
      "type": "string"
    },
    {
      "key": "resourceId",
      "value": "",
      "type": "string"
    },
    {
      "key": "requesterUserId",
      "value": "",
      "type": "string"
    },
    {
      "key": "skillId",
      "value": "",
      "type": "string"
    },
    {
      "key": "requestId",
      "value": "",
      "type": "string"
    }
  ]
}
